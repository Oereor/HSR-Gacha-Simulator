<Window x:Class="HSR_Gacha_Simulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:markup="clr-namespace:HSR_Gacha_Simulator.Markup"
        xmlns:services="clr-namespace:HSR_Gacha_Simulator.Services"
        mc:Ignorable="d"
        Title="{markup:Loc ui.window.title}"
        Height="750" Width="850"
        MinHeight="550" MinWidth="700"
        Background="#1a1a2e"
        Language="zh-CN"
        WindowStartupLocation="CenterScreen">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  Main Layout  (REVISION_10: single-column + ScrollViewer)  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{markup:Loc ui.lang.selector}"
                               VerticalAlignment="Center"
                               Foreground="#c0c0c0"
                               FontSize="13"
                               Margin="0,0,6,0" />
                    <ComboBox x:Name="cmbLanguage"
                              Width="72"
                              Height="24"
                              SelectedItem="{Binding Source={x:Static services:LocalizationService.Current},
                                                     Path=CurrentLanguage,
                                                     Mode=TwoWay}"
                              ItemsSource="{Binding Source={x:Static services:LocalizationService.Current},
                                                    Path=AvailableLanguages}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- 0: Banner Selection -->
                    <RowDefinition Height="Auto" />   <!-- 1: Controls + Stats -->
                    <RowDefinition Height="Auto" />   <!-- 2: Latest Pull Result -->
                    <RowDefinition Height="*" />      <!-- 3: Pull History -->
                </Grid.RowDefinitions>

            <!-- ── Row 0 : Banner Selection (horizontal scroll strip) ── -->
            <GroupBox Grid.Row="0"
                      Header="{markup:Loc ui.group.banner_selection}"
                      Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left scroll arrow -->
                    <Button Grid.Column="0"
                            Content="◀"
                            Style="{StaticResource NavButtonStyle}"
                            Width="28" Height="28"
                            Padding="0"
                            FontSize="12"
                            VerticalAlignment="Center"
                            Click="BannerScrollLeft_Click" />

                    <!-- Scrollable banner list -->
                    <ScrollViewer Grid.Column="1"
                                  x:Name="BannerScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="BannerScroll_MouseWheel"
                                  Margin="6,0">
                        <ListBox x:Name="BannerListBox"
                                 ItemsSource="{Binding Banners}"
                                 SelectedItem="{Binding SelectedBanner}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 RequestBringIntoView="BannerListBox_RequestBringIntoView">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="3,0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Pill button bound to BannerViewModel -->
                                    <Border x:Name="pill"
                                            Background="#16213e"
                                            BorderBrush="#3a3a6e"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14,5"
                                            Cursor="Hand">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#c0c0c0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="pill" Property="Background" Value="#3a3a6e" />
                                            <Setter TargetName="pill" Property="BorderBrush" Value="#ffd700" />
                                            <Setter TargetName="pill" Property="TextBlock.Foreground" Value="#ffffff" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Right scroll arrow -->
                    <Button Grid.Column="2"
                            Content="▶"
                            Style="{StaticResource NavButtonStyle}"
                            Width="28" Height="28"
                            Padding="0"
                            FontSize="12"
                            VerticalAlignment="Center"
                            Click="BannerScrollRight_Click" />
                </Grid>
            </GroupBox>

            <!-- ── Row 1 : Pull Controls + Statistics side by side ── -->
            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Pull Controls (left) -->
                <GroupBox Grid.Column="0"
                          Header="{markup:Loc ui.group.pull_controls}">
                    <StackPanel>
                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{markup:Loc ui.button.warp_x1}"
                                    Style="{StaticResource WarpButtonStyle}"
                                    Click="BtnWarp1_Click" />
                            <Button Content="{markup:Loc ui.button.warp_x10}"
                                    Style="{StaticResource WarpButtonStyle}"
                                    Margin="12,0,0,0"
                                    Click="BtnWarp10_Click" />
                        </StackPanel>

                        <Button Content="{markup:Loc ui.button.reset_banner}"
                                Style="{StaticResource ResetButtonStyle}"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Click="BtnReset_Click" />

                        <!-- Pity display -->
                        <StackPanel Margin="0,8,0,0">
                            <!-- Gold row -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{markup:Loc ui.pity.gold_pity}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{Binding PityStats.GoldPity}"
                                           Style="{StaticResource PityTextStyle}" />
                                <TextBlock Text="{markup:Loc ui.pity.gold_since}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#b0b0b0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{markup:Loc ui.pity.gold_guarantee}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{Binding PityStats.GoldGuarantee}"
                                           Foreground="{Binding PityStats.GoldGuaranteeBrush}"
                                           Style="{StaticResource PityTextStyle}" />
                            </StackPanel>
                            <!-- Purple row -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{markup:Loc ui.pity.purple_pity}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{Binding PityStats.PurplePity}"
                                           Style="{StaticResource PityTextStyle}" />
                                <TextBlock Text="{markup:Loc ui.pity.purple_since}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#b0b0b0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{markup:Loc ui.pity.purple_guarantee}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{Binding PityStats.PurpleGuarantee}"
                                           Foreground="{Binding PityStats.PurpleGuaranteeBrush}"
                                           Style="{StaticResource PityTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Statistics (right) -->
                <GroupBox Grid.Column="1"
                          Header="{markup:Loc ui.group.statistics}">
                    <StackPanel>
                        <!-- Total pulls -->
                        <TextBlock Text="{Binding PityStats.TotalPulls}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#e0e0e0"
                                   Margin="0,0,0,6" />

                        <!-- Rarity breakdown -->
                        <!-- 5★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="★★★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#ffd700"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{markup:Loc ui.stats.rarity_5star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock Text="{Binding PityStats.GoldCount}"
                                       Foreground="#ffd700"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PityStats.GoldRate}"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Missed gold stats row (hidden for ordinary banners) -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="14,1,0,0"
                                    Visibility="{Binding PityStats.MissedStatsVisibility}">
                            <TextBlock Text="↳"
                                       Foreground="#c77dff"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                            <TextBlock Text="{Binding PityStats.MissedGoldStats}"
                                       Foreground="#c77dff"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- 4★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="★★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#c77dff"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{markup:Loc ui.stats.rarity_4star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock Text="{Binding PityStats.PurpleCount}"
                                       Foreground="#c77dff"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PityStats.PurpleRate}"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- 3★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#6090ff"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{markup:Loc ui.stats.rarity_3star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock Text="{Binding PityStats.BlueCount}"
                                       Foreground="#6090ff"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PityStats.BlueRate}"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- ── Row 2 : Latest Pull Result ────────────────────── -->
            <GroupBox Grid.Row="2"
                      Header="{markup:Loc ui.group.latest_result}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Result card -->
                    <Border Grid.Row="0"
                            Background="#16213e"
                            BorderThickness="3"
                            CornerRadius="8"
                            Padding="20,16"
                            MinHeight="80"
                            HorizontalAlignment="Center"
                            MinWidth="400"
                            MaxWidth="600"
                            BorderBrush="{Binding ResultCard.ResultCardBorderBrush}">
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <!-- Left: Path icon -->
                                <Image Width="48" Height="48"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Source="{Binding ResultCard.ResultPathIcon}"
                                       Visibility="{Binding ResultCard.ResultPathIconVisibility}" />
                                <!-- Center: text stack -->
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ResultCard.ResultRarity}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4"
                                               Foreground="{Binding ResultCard.ResultRarityBrush}" />
                                    <TextBlock Text="{Binding ResultCard.ResultName}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#e0e0e0"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ResultCard.ResultType}"
                                                   FontSize="14"
                                                   Foreground="#c0c0c0" />
                                        <TextBlock Text="{markup:Loc ui.result.separator}"
                                                   FontSize="14"
                                                   Foreground="#b0b0b0" />
                                        <TextBlock Text="{Binding ResultCard.ResultPath}"
                                                   FontSize="14"
                                                   Foreground="#c0c0c0" />
                                        <TextBlock Text="{markup:Loc ui.result.separator}"
                                                   FontSize="14"
                                                   Foreground="#b0b0b0"
                                                   Visibility="{Binding ResultCard.DotElementVisibility}" />
                                        <TextBlock Text="{Binding ResultCard.ResultElement}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding ResultCard.ResultElementBrush}"
                                                   Visibility="{Binding ResultCard.ResultElementTextVisibility}" />
                                    </StackPanel>
                                </StackPanel>
                                <!-- Right: Element icon -->
                                <Image Width="48" Height="48"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Source="{Binding ResultCard.ResultElementIcon}"
                                       Visibility="{Binding ResultCard.ResultElementIconVisibility}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation buttons -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Content="{markup:Loc ui.button.prev_page}"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnPrevResult_Click" />
                        <TextBlock Text="{Binding ResultCard.ResultIndexText}"
                                   Foreground="#c0c0c0"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="16,0"
                                   MinWidth="100"
                                   TextAlignment="Center" />
                        <Button Content="{markup:Loc ui.button.next_page}"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnNextResult_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- ── Row 3 : Pull History ──────────────────────────── -->
            <GroupBox Grid.Row="3"
                      Header="{markup:Loc ui.group.pull_history}">
                <ListView x:Name="lvHistory"
                          HorizontalContentAlignment="Stretch">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{markup:Loc ui.history.header.number}"
                                            Width="50"
                                            DisplayMemberBinding="{Binding Index}" />
                            <GridViewColumn Header="{markup:Loc ui.history.header.name}"
                                            Width="180"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="{markup:Loc ui.history.header.rarity}"
                                            Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RarityStars}"
                                                   Foreground="{Binding Rarity,
                                                       Converter={StaticResource RarityForegroundConverter}}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{markup:Loc ui.history.header.type}"
                                            Width="60"
                                            DisplayMemberBinding="{Binding TypeLabel}" />
                            <GridViewColumn Header="{markup:Loc ui.history.header.path}"
                                            Width="90"
                                            DisplayMemberBinding="{Binding PathLabel}" />
                            <GridViewColumn Header="{markup:Loc ui.history.header.element}"
                                            Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ElementLabel}"
                                                   Foreground="{Binding ElementType,
                                                       Converter={StaticResource ElementBrushConverter}}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
