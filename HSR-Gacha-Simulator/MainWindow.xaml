<Window x:Class="HSR_Gacha_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HSR_Gacha_Simulator"
        mc:Ignorable="d"
        Title="{local:Loc ui.window.title}"
        Height="750" Width="850"
        MinHeight="550" MinWidth="700"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:ElementTypeToBrushConverter x:Key="ElementBrushConverter" />

        <!-- ── Brushes ─────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDarkBrush"        Color="#1a1a2e" />
        <SolidColorBrush x:Key="BgCardBrush"        Color="#16213e" />
        <SolidColorBrush x:Key="BtnBgBrush"         Color="#3a3a6e" />
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#e0e0e0" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#c0c0c0" />
        <SolidColorBrush x:Key="TextDimBrush"       Color="#b0b0b0" />
        <SolidColorBrush x:Key="GoldAccentBrush"    Color="#ffd700" />
        <SolidColorBrush x:Key="PurpleAccentBrush"  Color="#c77dff" />
        <SolidColorBrush x:Key="BlueAccentBrush"    Color="#6090ff" />
        <SolidColorBrush x:Key="StatusBarBrush"     Color="#0f3460" />

        <!-- ── Styles ──────────────────────────────────────── -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#3a3a6e" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Background"       Value="#16213e" />
            <Setter Property="Padding"          Value="10" />
            <Setter Property="Margin"           Value="5" />
            <Setter Property="FontWeight"       Value="SemiBold" />
        </Style>

        <Style x:Key="WarpButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#3a3a6e" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#5a5a8e" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="FontSize"         Value="16" />
            <Setter Property="FontWeight"       Value="Bold" />
            <Setter Property="Padding"          Value="16,8" />
            <Setter Property="MinWidth"         Value="120" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a4a8e" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2a2a5e" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#3a3a6e" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#5a5a8e" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="Padding"          Value="8,4" />
            <Setter Property="MinWidth"         Value="80" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a4a8e" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadioBannerStyle" TargetType="RadioButton">
            <Setter Property="Foreground"       Value="#c0c0c0" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Margin"           Value="8,0" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="#16213e"
                                BorderBrush="#3a3a6e"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3a6e" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#ffd700" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5a5a8e" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background"        Value="#16213e" />
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="BorderBrush"       Value="#3a3a6e" />
            <Setter Property="BorderThickness"   Value="1" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background"        Value="Transparent" />
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="BorderBrush"       Value="#2a2a4e" />
            <Setter Property="BorderThickness"   Value="0,0,0,1" />
            <Setter Property="Padding"           Value="4,2" />
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background"        Value="#0f3460" />
            <Setter Property="Foreground"        Value="#c0c0c0" />
        </Style>

        <Style x:Key="PityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="FontSize"          Value="14" />
            <Setter Property="Margin"            Value="4,0" />
        </Style>

        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#6e3a3a" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#8e4a4a" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Padding"          Value="14,8" />
            <Setter Property="MinWidth"         Value="120" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8e4a4a" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#4e2a2a" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBoxItem (dropdown items) ─────────────────── -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"       Value="#16213e" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="Padding"          Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3a6e" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3a6e" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox (dark-themed, non-editable) ──────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#16213e" />
            <Setter Property="Foreground"       Value="#ffffff" />
            <Setter Property="BorderBrush"      Value="#3a3a6e" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="4,2" />
            <Setter Property="FontSize"         Value="13" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,2,0,2"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                                      Path=(ComboBox.SelectionBoxItem)}"
                                                                  ContentTemplate="{TemplateBinding ComboBox.SelectionBoxItemTemplate}"
                                                                  TextBlock.Foreground="#ffffff" />
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#c0c0c0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      StrokeThickness="0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#16213e"
                                        BorderBrush="#3a3a6e"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,1,0,0">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Rarity → Brush converter for result card border ── -->
        <local:RarityToBorderBrushConverter x:Key="RarityBorderConverter" />
        <local:RarityToForegroundConverter x:Key="RarityForegroundConverter" />
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  Main Layout  (REVISION_10: single-column + ScrollViewer)  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus"
                           Text="{local:Loc ui.status.ready}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{local:Loc ui.lang.selector}"
                               VerticalAlignment="Center"
                               Foreground="#c0c0c0"
                               FontSize="13"
                               Margin="0,0,6,0" />
                    <ComboBox x:Name="cmbLanguage"
                              Width="72"
                              Height="24"
                              SelectedItem="{Binding Source={x:Static local:LocalizationService.Instance},
                                                     Path=CurrentLanguage,
                                                     Mode=TwoWay}"
                              ItemsSource="{Binding Source={x:Static local:LocalizationService.Instance},
                                                    Path=AvailableLanguages}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- 0: Banner Selection -->
                    <RowDefinition Height="Auto" />   <!-- 1: Controls + Stats -->
                    <RowDefinition Height="Auto" />   <!-- 2: Latest Pull Result -->
                    <RowDefinition Height="*" />      <!-- 3: Pull History -->
                </Grid.RowDefinitions>

            <!-- ── Row 0 : Banner Selection ──────────────────────── -->
            <GroupBox Grid.Row="0"
                      Header="{local:Loc ui.group.banner_selection}">
                <StackPanel>
                    <!-- Event Warps row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton x:Name="rbOrdinary"
                                     Content="{local:Loc ui.banner.ordinary}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     IsChecked="True"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbCyreneAvatar"
                                     Content="{local:Loc ui.banner.cyrene_avatar}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbPhainonAvatar"
                                     Content="{local:Loc ui.banner.phainon_avatar}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbCyreneLC"
                                     Content="{local:Loc ui.banner.cyrene_lc}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbPhainonLC"
                                     Content="{local:Loc ui.banner.phainon_lc}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                    </StackPanel>

                    <!-- Collab Warps row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,6,0,0">
                        <RadioButton x:Name="rbArcherAvatar"
                                     Content="{local:Loc ui.banner.archer_avatar}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbArcherLC"
                                     Content="{local:Loc ui.banner.archer_lc}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbSaberAvatar"
                                     Content="{local:Loc ui.banner.saber_avatar}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                        <RadioButton x:Name="rbSaberLC"
                                     Content="{local:Loc ui.banner.saber_lc}"
                                     Style="{StaticResource RadioBannerStyle}"
                                     GroupName="Banner"
                                     Checked="Banner_Changed" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- ── Row 1 : Pull Controls + Statistics side by side ── -->
            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Pull Controls (left) -->
                <GroupBox Grid.Column="0"
                          Header="{local:Loc ui.group.pull_controls}">
                    <StackPanel>
                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnWarp1"
                                    Content="{local:Loc ui.button.warp_x1}"
                                    Style="{StaticResource WarpButtonStyle}"
                                    Click="BtnWarp1_Click" />
                            <Button x:Name="btnWarp10"
                                    Content="{local:Loc ui.button.warp_x10}"
                                    Style="{StaticResource WarpButtonStyle}"
                                    Margin="12,0,0,0"
                                    Click="BtnWarp10_Click" />
                        </StackPanel>

                        <Button x:Name="btnReset"
                                Content="{local:Loc ui.button.reset_banner}"
                                Style="{StaticResource ResetButtonStyle}"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Click="BtnReset_Click" />

                        <!-- Pity display -->
                        <StackPanel Margin="0,8,0,0">
                            <!-- Gold row -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{local:Loc ui.pity.gold_pity}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock x:Name="txtGoldPity"
                                           Text="0"
                                           Style="{StaticResource PityTextStyle}" />
                                <TextBlock Text="{local:Loc ui.pity.gold_since}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#b0b0b0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{local:Loc ui.pity.gold_guarantee}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock x:Name="txtGoldGuarantee"
                                           Text="{local:Loc ui.pity.not_guaranteed}"
                                           Style="{StaticResource PityTextStyle}" />
                            </StackPanel>
                            <!-- Purple row -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{local:Loc ui.pity.purple_pity}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock x:Name="txtPurplePity"
                                           Text="0"
                                           Style="{StaticResource PityTextStyle}" />
                                <TextBlock Text="{local:Loc ui.pity.purple_since}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#b0b0b0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{local:Loc ui.pity.purple_guarantee}"
                                           Style="{StaticResource PityTextStyle}"
                                           Foreground="#c0c0c0" />
                                <TextBlock x:Name="txtPurpleGuarantee"
                                           Text="{local:Loc ui.pity.not_guaranteed}"
                                           Style="{StaticResource PityTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Statistics (right) -->
                <GroupBox Grid.Column="1"
                          Header="{local:Loc ui.group.statistics}">
                    <StackPanel>
                        <!-- Total pulls -->
                        <TextBlock x:Name="txtTotalPulls"
                                   Text=""
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#e0e0e0"
                                   Margin="0,0,0,6" />

                        <!-- Rarity breakdown -->
                        <!-- 5★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock x:Name="txtGoldStars"
                                       Text="★★★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#ffd700"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{local:Loc ui.stats.rarity_5star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock x:Name="txtGoldCount"
                                       Text="0"
                                       Foreground="#ffd700"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="txtGoldRate"
                                       Text="  (—)"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- 4★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="★★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#c77dff"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{local:Loc ui.stats.rarity_4star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock x:Name="txtPurpleCount"
                                       Text="0"
                                       Foreground="#c77dff"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="txtPurpleRate"
                                       Text="  (—)"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- 3★ row -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="★★★"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#6090ff"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{local:Loc ui.stats.rarity_3star}"
                                       Foreground="#c0c0c0"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="80" />
                            <TextBlock x:Name="txtBlueCount"
                                       Text="0"
                                       Foreground="#6090ff"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="txtBlueRate"
                                       Text="  (—)"
                                       Foreground="#b0b0b0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- ── Row 2 : Latest Pull Result ────────────────────── -->
            <GroupBox Grid.Row="2"
                      Header="{local:Loc ui.group.latest_result}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Result card -->
                    <Border x:Name="resultCardBorder"
                            Grid.Row="0"
                            Background="#16213e"
                            BorderThickness="3"
                            CornerRadius="8"
                            Padding="20,16"
                            MinHeight="80"
                            HorizontalAlignment="Center"
                            MinWidth="400"
                            MaxWidth="600">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="txtResultRarity"
                                       Text="★★★★★"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="txtResultName"
                                       Text="{local:Loc ui.result.default}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#e0e0e0"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0">
                                <TextBlock x:Name="txtResultType"
                                           Text=""
                                           FontSize="14"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{local:Loc ui.result.separator}"
                                           FontSize="14"
                                           Foreground="#b0b0b0" />
                                <TextBlock x:Name="txtResultPath"
                                           Text=""
                                           FontSize="14"
                                           Foreground="#c0c0c0" />
                                <TextBlock Text="{local:Loc ui.result.separator}"
                                           FontSize="14"
                                           Foreground="#b0b0b0"
                                           x:Name="dotElement" />
                                <TextBlock x:Name="txtResultElement"
                                           Text=""
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock x:Name="txtResultPullNum"
                                       Text=""
                                       FontSize="12"
                                       Foreground="#b0b0b0"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Navigation buttons -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Content="{local:Loc ui.button.prev_page}"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnPrevResult_Click" />
                        <TextBlock x:Name="txtResultIndex"
                                   Text=""
                                   Foreground="#c0c0c0"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="16,0"
                                   MinWidth="100"
                                   TextAlignment="Center" />
                        <Button Content="{local:Loc ui.button.next_page}"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnNextResult_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- ── Row 3 : Pull History ──────────────────────────── -->
            <GroupBox Grid.Row="3"
                      Header="{local:Loc ui.group.pull_history}">
                <ListView x:Name="lvHistory"
                          HorizontalContentAlignment="Stretch">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{local:Loc ui.history.header.number}"
                                            Width="50"
                                            DisplayMemberBinding="{Binding Index}" />
                            <GridViewColumn Header="{local:Loc ui.history.header.name}"
                                            Width="180"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="{local:Loc ui.history.header.rarity}"
                                            Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RarityStars}"
                                                   Foreground="{Binding Rarity,
                                                       Converter={StaticResource RarityForegroundConverter}}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{local:Loc ui.history.header.type}"
                                            Width="60"
                                            DisplayMemberBinding="{Binding TypeLabel}" />
                            <GridViewColumn Header="{local:Loc ui.history.header.path}"
                                            Width="90"
                                            DisplayMemberBinding="{Binding PathLabel}" />
                            <GridViewColumn Header="{local:Loc ui.history.header.element}"
                                            Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ElementLabel}"
                                                   Foreground="{Binding ElementType,
                                                       Converter={StaticResource ElementBrushConverter}}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
