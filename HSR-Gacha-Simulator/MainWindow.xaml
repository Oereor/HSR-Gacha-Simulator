<Window x:Class="HSR_Gacha_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HSR_Gacha_Simulator"
        mc:Ignorable="d"
        Title="HSR Gacha Simulator"
        Height="1100" Width="900"
        MinHeight="600" MinWidth="800"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:ElementTypeToBrushConverter x:Key="ElementBrushConverter" />

        <!-- ── Brushes ─────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDarkBrush"        Color="#1a1a2e" />
        <SolidColorBrush x:Key="BgCardBrush"        Color="#16213e" />
        <SolidColorBrush x:Key="BtnBgBrush"         Color="#3a3a6e" />
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#e0e0e0" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#c0c0c0" />
        <SolidColorBrush x:Key="TextDimBrush"       Color="#b0b0b0" />
        <SolidColorBrush x:Key="GoldAccentBrush"    Color="#ffd700" />
        <SolidColorBrush x:Key="PurpleAccentBrush"  Color="#c77dff" />
        <SolidColorBrush x:Key="BlueAccentBrush"    Color="#6090ff" />
        <SolidColorBrush x:Key="StatusBarBrush"     Color="#0f3460" />

        <!-- ── Styles ──────────────────────────────────────── -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#3a3a6e" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Background"       Value="#16213e" />
            <Setter Property="Padding"          Value="10" />
            <Setter Property="Margin"           Value="5" />
            <Setter Property="FontWeight"       Value="SemiBold" />
        </Style>

        <Style x:Key="WarpButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#3a3a6e" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#5a5a8e" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="FontSize"         Value="16" />
            <Setter Property="FontWeight"       Value="Bold" />
            <Setter Property="Padding"          Value="16,8" />
            <Setter Property="MinWidth"         Value="120" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a4a8e" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2a2a5e" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#3a3a6e" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#5a5a8e" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="Padding"          Value="8,4" />
            <Setter Property="MinWidth"         Value="80" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a4a8e" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadioBannerStyle" TargetType="RadioButton">
            <Setter Property="Foreground"       Value="#c0c0c0" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Margin"           Value="8,0" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="#16213e"
                                BorderBrush="#3a3a6e"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3a6e" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#ffd700" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5a5a8e" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background"        Value="#16213e" />
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="BorderBrush"       Value="#3a3a6e" />
            <Setter Property="BorderThickness"   Value="1" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background"        Value="Transparent" />
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="BorderBrush"       Value="#2a2a4e" />
            <Setter Property="BorderThickness"   Value="0,0,0,1" />
            <Setter Property="Padding"           Value="4,2" />
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background"        Value="#0f3460" />
            <Setter Property="Foreground"        Value="#c0c0c0" />
        </Style>

        <Style x:Key="PityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#e0e0e0" />
            <Setter Property="FontSize"          Value="14" />
            <Setter Property="Margin"            Value="4,0" />
        </Style>

        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#6e3a3a" />
            <Setter Property="Foreground"       Value="#e0e0e0" />
            <Setter Property="BorderBrush"      Value="#8e4a4a" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="FontSize"         Value="14" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Padding"          Value="14,8" />
            <Setter Property="MinWidth"         Value="120" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8e4a4a" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#4e2a2a" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Rarity → Brush converter for result card border ── -->
        <local:RarityToBorderBrushConverter x:Key="RarityBorderConverter" />
        <local:RarityToForegroundConverter x:Key="RarityForegroundConverter" />
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  Main Layout                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- 0: Banner Selection -->
                <RowDefinition Height="Auto" />   <!-- 1: Pull Controls   -->
                <RowDefinition Height="Auto" />   <!-- 2: Statistics      -->
                <RowDefinition Height="Auto" />   <!-- 3: Result Card     -->
                <RowDefinition Height="*"    />   <!-- 4: History List    -->
            </Grid.RowDefinitions>

        <!-- ── Row 0 : Banner Selection ──────────────────────── -->
        <GroupBox Grid.Row="0" Header="Banner Selection">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="rbOrdinary"
                             Content="Ordinary"
                             Style="{StaticResource RadioBannerStyle}"
                             GroupName="Banner"
                             IsChecked="True"
                             Checked="Banner_Changed" />
                <RadioButton x:Name="rbCyreneAvatar"
                             Content="Cyrene (Avatar)"
                             Style="{StaticResource RadioBannerStyle}"
                             GroupName="Banner"
                             Checked="Banner_Changed" />
                <RadioButton x:Name="rbPhainonAvatar"
                             Content="Phainon (Avatar)"
                             Style="{StaticResource RadioBannerStyle}"
                             GroupName="Banner"
                             Checked="Banner_Changed" />
                <RadioButton x:Name="rbCyreneLC"
                             Content="Cyrene (LC)"
                             Style="{StaticResource RadioBannerStyle}"
                             GroupName="Banner"
                             Checked="Banner_Changed" />
                <RadioButton x:Name="rbPhainonLC"
                             Content="Phainon (LC)"
                             Style="{StaticResource RadioBannerStyle}"
                             GroupName="Banner"
                             Checked="Banner_Changed" />
            </StackPanel>
        </GroupBox>

        <!-- ── Row 1 : Pull Controls ─────────────────────────── -->
        <GroupBox Grid.Row="1" Header="Pull Controls">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button x:Name="btnWarp1"
                            Content="Warp ×1"
                            Style="{StaticResource WarpButtonStyle}"
                            Click="BtnWarp1_Click" />
                    <Button x:Name="btnWarp10"
                            Content="Warp ×10"
                            Style="{StaticResource WarpButtonStyle}"
                            Margin="12,0,0,0"
                            Click="BtnWarp10_Click" />
                    <Button x:Name="btnReset"
                            Content="Reset Banner"
                            Style="{StaticResource ResetButtonStyle}"
                            Margin="16,0,0,0"
                            Click="BtnReset_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Gold row -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Gold pity:"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#c0c0c0" />
                        <TextBlock x:Name="txtGoldPity"
                                   Text="0"
                                   Style="{StaticResource PityTextStyle}" />
                        <TextBlock Text="pulls since last 5★"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#b0b0b0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Gold guarantee:"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#c0c0c0" />
                        <TextBlock x:Name="txtGoldGuarantee"
                                   Text="Not Guaranteed"
                                   Style="{StaticResource PityTextStyle}" />
                    </StackPanel>
                    <!-- Purple row -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Purple pity:"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#c0c0c0" />
                        <TextBlock x:Name="txtPurplePity"
                                   Text="0"
                                   Style="{StaticResource PityTextStyle}" />
                        <TextBlock Text="pulls since last 4★"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#b0b0b0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Purple guarantee:"
                                   Style="{StaticResource PityTextStyle}"
                                   Foreground="#c0c0c0" />
                        <TextBlock x:Name="txtPurpleGuarantee"
                                   Text="Not Guaranteed"
                                   Style="{StaticResource PityTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ── Row 2 : Statistics ──────────────────────────────── -->
        <GroupBox Grid.Row="2" Header="Statistics">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Total pulls -->
                <TextBlock x:Name="txtTotalPulls"
                           Grid.Row="0"
                           Text="Total Pulls: 0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#e0e0e0"
                           Margin="0,0,0,6" />

                <!-- Rarity breakdown -->
                <StackPanel Grid.Row="1">
                    <!-- 5★ row -->
                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock x:Name="txtGoldStars"
                                   Text="★★★★★"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#ffd700"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" 5★ Gold    "
                                   Foreground="#c0c0c0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtGoldCount"
                                   Text="0"
                                   Foreground="#ffd700"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtGoldRate"
                                   Text="  (—)"
                                   Foreground="#b0b0b0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 4★ row -->
                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock Text="★★★★"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#c77dff"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  4★ Purple  "
                                   Foreground="#c0c0c0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtPurpleCount"
                                   Text="0"
                                   Foreground="#c77dff"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtPurpleRate"
                                   Text="  (—)"
                                   Foreground="#b0b0b0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 3★ row -->
                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock Text="★★★"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#6090ff"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="   3★ Blue    "
                                   Foreground="#c0c0c0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtBlueCount"
                                   Text="0"
                                   Foreground="#6090ff"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="txtBlueRate"
                                   Text="  (—)"
                                   Foreground="#b0b0b0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ── Row 3 : Latest Pull Result ────────────────────── -->
        <GroupBox Grid.Row="3" Header="Latest Pull Result">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Result card -->
                <Border x:Name="resultCardBorder"
                        Grid.Row="0"
                        Background="#16213e"
                        BorderThickness="3"
                        CornerRadius="8"
                        Padding="20,16"
                        MinHeight="80"
                        HorizontalAlignment="Center"
                        MinWidth="400"
                        MaxWidth="600">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="txtResultRarity"
                                   Text="★★★★★"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock x:Name="txtResultName"
                                   Text="Pull to begin"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#e0e0e0"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0">
                            <TextBlock x:Name="txtResultType"
                                       Text=""
                                       FontSize="14"
                                       Foreground="#c0c0c0" />
                            <TextBlock Text=" · "
                                       FontSize="14"
                                       Foreground="#b0b0b0" />
                            <TextBlock x:Name="txtResultPath"
                                       Text=""
                                       FontSize="14"
                                       Foreground="#c0c0c0" />
                            <TextBlock Text=" · "
                                       FontSize="14"
                                       Foreground="#b0b0b0"
                                       x:Name="dotElement" />
                            <TextBlock x:Name="txtResultElement"
                                       Text=""
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock x:Name="txtResultPullNum"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#b0b0b0"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Navigation buttons -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <Button Content="◄ Previous"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnPrevResult_Click" />
                    <TextBlock x:Name="txtResultIndex"
                               Text=""
                               Foreground="#c0c0c0"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               MinWidth="100"
                               TextAlignment="Center" />
                    <Button Content="Next ►"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnNextResult_Click" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ── Row 4 : Pull History ──────────────────────────── -->
        <GroupBox Grid.Row="4" Header="Pull History">
            <ListView x:Name="lvHistory"
                      HorizontalContentAlignment="Stretch">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="50"
                                        DisplayMemberBinding="{Binding Index}" />
                        <GridViewColumn Header="Name" Width="180"
                                        DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Rarity" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RarityStars}"
                                               Foreground="{Binding Rarity,
                                                   Converter={StaticResource RarityForegroundConverter}}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Type" Width="60"
                                        DisplayMemberBinding="{Binding TypeLabel}" />
                        <GridViewColumn Header="Path" Width="90"
                                        DisplayMemberBinding="{Binding PathLabel}" />
                        <GridViewColumn Header="Element" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ElementLabel}"
                                               Foreground="{Binding ElementType,
                                                   Converter={StaticResource ElementBrushConverter}}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
        </Grid>
    </DockPanel>
</Window>
